# ── Backend API URL ──────────────────────────────────────────
# Local dev: leave blank (Vite proxy handles /api → localhost:5000)
# Production on Vercel: set to your Render backend URL
VITE_API_URL=https://your-adzo-backend.onrender.com/api

# ── Razorpay public key (frontend safe) ──────────────────────
VITE_RAZORPAY_KEY_ID=rzp_live_...
